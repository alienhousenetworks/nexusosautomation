# =============================================
# NexusOS Environment Configuration
# Copy this file to .env and fill in values
# =============================================

# --- Database ---
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nexusos

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AI Provider Keys ---
ANTHROPIC_API_KEY=CHANGE_ME_YOUR_ANTHROPIC_KEY
OPENAI_API_KEY=CHANGE_ME_YOUR_OPENAI_KEY

# --- SMTP / Email ---
DEV=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=CHANGE_ME_YOUR_GMAIL@gmail.com
EMAIL_HOST_PASSWORD=CHANGE_ME_YOUR_APP_PASSWORD
DEFAULT_FROM_EMAIL=CHANGE_ME_YOUR_GMAIL@gmail.com

# --- App / Domain ---
DOMAIN=CHANGE_ME_YOUR_DOMAIN.com
SERVER_IP=CHANGE_ME_YOUR_SERVER_IP

# --- Security ---
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=https://CHANGE_ME_YOUR_DOMAIN.com/api/v1
