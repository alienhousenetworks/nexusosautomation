{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node10",
      "ignoreDeprecations": "5.0"
    }
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": ["node_modules"]
}
